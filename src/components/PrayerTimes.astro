---
import iqamaConfig from '../data/iqama-times.json';
import { url } from '../utils/links';

const prayers = [
  { key: 'fajr', name: 'Fajr', arabic: 'الفجر' },
  { key: 'dhuhr', name: 'Dhuhr', arabic: 'الظهر' },
  { key: 'asr', name: 'Asr', arabic: 'العصر' },
  { key: 'maghrib', name: 'Maghrib', arabic: 'المغرب' },
  { key: 'isha', name: 'Isha', arabic: 'العشاء' },
];

const jummahTimes = iqamaConfig.jummah.khutbah;
const iqama = iqamaConfig.iqama as Record<string, string>;

function displayIqama(key: string): string {
  const val = iqama[key];
  if (!val) return '--:--';
  const v = val.trim().toLowerCase();
  if (v === 'same' || v === 'adhan' || v.startsWith('+') || /^\d{1,3}$/.test(v)) return '--:--';
  return val;
}
---

<section class="py-12 sm:py-16 bg-gradient-to-b from-gray-50 to-white" id="prayer-times">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 font-heading mb-2">Prayer Times</h2>
      <p class="text-gray-600 text-sm sm:text-base">Daily prayers at Prince William Islamic Center</p>
    </div>

    <div class="max-w-5xl mx-auto">
      <!-- Live Clock -->
      <div class="text-center mb-6">
        <div class="inline-flex items-center gap-3 bg-primary-800 text-white px-6 py-3 rounded-2xl shadow-lg">
          <svg class="w-5 h-5 text-primary-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span id="live-clock" class="text-xl font-bold tabular-nums">--:-- --</span>
          <span class="text-primary-300 text-sm">|</span>
          <span id="hijri-date" class="text-sm text-primary-200">Loading...</span>
        </div>
      </div>

      <!-- Next Prayer Indicator -->
      <div class="text-center mb-6">
        <div class="inline-flex items-center gap-2 bg-amber-50 border border-amber-200 text-amber-800 px-4 py-2 rounded-full text-sm font-medium">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-amber-500"></span>
          </span>
          <span id="next-prayer-text">Calculating next prayer...</span>
        </div>
      </div>

      <!-- Prayer Cards -->
      <div class="grid grid-cols-3 sm:grid-cols-6 gap-3 sm:gap-4">
        <!-- Jummah -->
        <div class="bg-gradient-to-br from-primary-700 to-primary-800 rounded-xl p-4 sm:p-5 text-center shadow-lg">
          <div class="text-white/70 text-xs sm:text-sm font-medium uppercase tracking-wide mb-1">Friday</div>
          <h4 class="text-white font-semibold text-base sm:text-lg mb-0.5">Jumu'ah</h4>
          <p class="text-xl sm:text-2xl font-bold text-white">{jummahTimes[0]}</p>
          {jummahTimes.length > 1 && (
            <p class="text-xs text-white/60 mt-1">2nd: {jummahTimes[1]}</p>
          )}
        </div>

        <!-- Daily Prayers -->
        {prayers.map((prayer) => (
          <div
            class="prayer-card bg-white rounded-xl p-4 sm:p-5 text-center shadow-md border border-gray-100 hover:shadow-lg transition-all duration-300"
            data-prayer={prayer.key}
          >
            <div class="text-primary-500 text-xs sm:text-sm font-medium mb-1">{prayer.arabic}</div>
            <h4 class="text-gray-800 font-semibold text-base sm:text-lg mb-1">{prayer.name}</h4>
            <div class="space-y-0.5">
              <p id={`adhan-${prayer.key}`} class="text-xs text-gray-400 tabular-nums">--:--</p>
              <p id={`iqama-${prayer.key}`} class="text-xl sm:text-2xl font-bold text-primary-700 tabular-nums">
                {displayIqama(prayer.key)}
              </p>
            </div>
            <div class="flex justify-center gap-1 mt-1.5">
              <span class="text-[10px] text-gray-400 uppercase tracking-wider">Athan</span>
              <span class="text-[10px] text-gray-300">|</span>
              <span class="text-[10px] text-primary-500 uppercase tracking-wider font-medium">Iqama</span>
            </div>
          </div>
        ))}
      </div>

      <!-- Action Buttons -->
      <div class="mt-6 flex flex-wrap justify-center gap-2">
        <a
          href={url('/screen')}
          target="_blank"
          class="inline-flex items-center gap-1.5 px-4 py-2 bg-primary-600 text-white rounded-full hover:bg-primary-700 transition-colors font-medium text-sm"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          TV Display
        </a>
      </div>

      <p class="mt-4 text-center text-gray-500 text-xs sm:text-sm">
        Athan times calculated using ISNA method. Iqama times set by the masjid.
      </p>
    </div>
  </div>
</section>

<div id="prayer-config-data" data-config={JSON.stringify(iqamaConfig)} hidden></div>

<script>
  import { createEngine } from '../lib/prayer-engine';
  import { fetchIqamaFromSheet, applyOverrides } from '../lib/iqama-remote';

  const configEl = document.getElementById('prayer-config-data')!;
  const config = JSON.parse(configEl.getAttribute('data-config')!);
  let engine = createEngine(config);

  function updateIqamaDom() {
    const keys = ['fajr', 'dhuhr', 'asr', 'maghrib', 'isha'];
    for (const key of keys) {
      const iqEl = document.getElementById('iqama-' + key);
      if (!iqEl) continue;
      const val = config.iqama[key];
      if (val && !val.startsWith('+')) {
        iqEl.textContent = val;
      }
    }
    const jummahEl = document.querySelector('.bg-gradient-to-br .text-xl, .bg-gradient-to-br .sm\\:text-2xl');
    if (jummahEl && config.jummah?.khutbah?.[0]) {
      jummahEl.textContent = config.jummah.khutbah[0];
    }
  }

  function updateAll() {
    const now = new Date();
    const times = engine.getTimes(now);
    const next = engine.getNext(now);
    const clock = engine.getClock(now);

    const clockEl = document.getElementById('live-clock');
    if (clockEl) clockEl.textContent = clock.full;

    const hijriEl = document.getElementById('hijri-date');
    if (hijriEl) hijriEl.textContent = engine.getHijriDate(now);

    for (const p of times) {
      const adhanEl = document.getElementById('adhan-' + p.key);
      if (adhanEl) adhanEl.textContent = engine.fmt(p.adhan);

      if (p.isRelative) {
        const iqEl = document.getElementById('iqama-' + p.key);
        if (iqEl) iqEl.textContent = engine.fmt(p.iqama);
      }
    }

    document.querySelectorAll('.prayer-card').forEach(card => {
      const key = card.getAttribute('data-prayer');
      if (key === next.key) {
        card.classList.add('ring-2', 'ring-primary-500', 'bg-primary-50', 'scale-[1.02]');
        card.classList.remove('bg-white');
      } else {
        card.classList.remove('ring-2', 'ring-primary-500', 'bg-primary-50', 'scale-[1.02]');
        card.classList.add('bg-white');
      }
    });

    const badge = document.getElementById('next-prayer-text');
    if (badge) {
      const cd = engine.formatCountdown(next.iqama, now);
      badge.textContent = 'Next: ' + next.name + ' ' + (cd || 'now');
    }
  }

  async function fetchSheet() {
    if (!config.googleSheetCsvUrl) return;
    const overrides = await fetchIqamaFromSheet(config.googleSheetCsvUrl);
    if (overrides) {
      engine = applyOverrides(config, overrides, createEngine);
      updateIqamaDom();
    }
  }

  updateAll();
  setInterval(updateAll, 1000);
  fetchSheet();
  setInterval(fetchSheet, 5 * 60 * 1000);
</script>
