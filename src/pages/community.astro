---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import { url } from '../utils/links';

const communityGallery = [
  {
    src: url('/images/community-iftar-gathering.png'),
    alt: 'Community Iftar gathering during Ramadan',
    caption: 'Ramadan Iftar',
  },
  {
    src: url('/images/community-iftar-dining.png'),
    alt: 'Community members sharing a meal together',
    caption: 'Breaking Fast Together',
  },
  {
    src: url('/images/community-iftar-food.png'),
    alt: 'Iftar food preparation and desserts',
    caption: 'Iftar Preparation',
  },
];
---

<Layout title="Our Community">
  <Hero
    title="Our Community"
    subtitle="Discover the vibrant life at PWIC — from Ramadan iftars to youth programs and more"
    backgroundImage="/images/community-iftar-gathering.png"
  />

  <!-- Community Highlights -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block px-4 py-1.5 bg-primary-100 text-primary-700 rounded-full text-sm font-semibold mb-4">Life at PWIC</span>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-800 font-heading mb-4">Community Gatherings</h2>
        <p class="text-gray-600 max-w-2xl mx-auto text-lg">
          Our masjid is more than a place of worship — it's a home where families come together, children grow, and bonds are strengthened.
        </p>
      </div>

      <!-- Masonry-style Photo Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {communityGallery.map((photo, index) => (
          <div class={`group relative rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 ${index === 0 ? 'sm:col-span-2 sm:row-span-2' : ''}`}>
            <img
              src={photo.src}
              alt={photo.alt}
              class={`w-full object-cover group-hover:scale-105 transition-transform duration-700 ${index === 0 ? 'h-72 sm:h-full sm:min-h-[28rem]' : 'h-72'}`}
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="absolute bottom-0 left-0 right-0 p-5 translate-y-full group-hover:translate-y-0 transition-transform duration-500">
              <p class="text-white font-semibold text-lg">{photo.caption}</p>
              <p class="text-white/80 text-sm mt-1">{photo.alt}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Ramadan at PWIC -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 items-center">
        <div>
          <span class="inline-block px-4 py-1.5 bg-amber-100 text-amber-700 rounded-full text-sm font-semibold mb-4">Ramadan Kareem</span>
          <h2 class="text-3xl font-bold text-gray-800 font-heading mb-6">Ramadan at PWIC</h2>
          <p class="text-gray-600 text-lg leading-relaxed mb-6">
            Every Ramadan, our community comes alive with Saturday iftars, taraweeh prayers, and
            special programs for all ages. Volunteers and families come together to prepare meals,
            welcome guests, and share in the blessings of the holy month.
          </p>
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-white rounded-xl p-5 border border-gray-100 shadow-sm">
              <div class="text-3xl font-bold text-primary-600 mb-1">Every</div>
              <div class="text-sm text-gray-500">Saturday Iftar</div>
            </div>
            <div class="bg-white rounded-xl p-5 border border-gray-100 shadow-sm">
              <div class="text-3xl font-bold text-primary-600 mb-1">200+</div>
              <div class="text-sm text-gray-500">Meals Served</div>
            </div>
            <div class="bg-white rounded-xl p-5 border border-gray-100 shadow-sm">
              <div class="text-3xl font-bold text-primary-600 mb-1">50+</div>
              <div class="text-sm text-gray-500">Volunteers</div>
            </div>
            <div class="bg-white rounded-xl p-5 border border-gray-100 shadow-sm">
              <div class="text-3xl font-bold text-primary-600 mb-1">All</div>
              <div class="text-sm text-gray-500">Are Welcome</div>
            </div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="rounded-2xl overflow-hidden shadow-xl">
            <img
              src={url('/images/community-iftar-gathering.png')}
              alt="Iftar gathering"
              class="w-full h-52 sm:h-64 object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <div class="rounded-2xl overflow-hidden shadow-xl mt-8">
            <img
              src={url('/images/community-iftar-dining.png')}
              alt="Community dining"
              class="w-full h-52 sm:h-64 object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <div class="rounded-2xl overflow-hidden shadow-xl col-span-2">
            <img
              src={url('/images/community-iftar-food.png')}
              alt="Iftar food and desserts"
              class="w-full h-52 sm:h-64 object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Youth Programs -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 items-center">
        <div class="order-2 lg:order-1">
          <div class="rounded-2xl overflow-hidden shadow-xl">
            <img
              src={url('/images/community-kids-soccer.png')}
              alt="Children participating in youth soccer program"
              class="w-full h-72 sm:h-96 object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <span class="inline-block px-4 py-1.5 bg-blue-100 text-blue-700 rounded-full text-sm font-semibold mb-4">Youth & Family</span>
          <h2 class="text-3xl font-bold text-gray-800 font-heading mb-6">Youth Activities</h2>
          <p class="text-gray-600 text-lg leading-relaxed mb-6">
            Our youth programs go beyond the classroom. From arts and team-building activities
            to weekend school, we foster an environment where children develop confidence,
            friendships, and a strong sense of community.
          </p>
          <div class="flex flex-col gap-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
              </div>
              <span class="text-gray-700 font-medium">Weekend Islamic school</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
              </div>
              <span class="text-gray-700 font-medium">Family-friendly events & outings</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Safety & Security -->
  <section class="py-16 bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 items-center">
        <div>
          <span class="inline-block px-4 py-1.5 bg-green-500/20 text-green-300 rounded-full text-sm font-semibold mb-4 border border-green-500/30">Safety First</span>
          <h2 class="text-3xl font-bold font-heading mb-6">A Safe & Secure Space</h2>
          <p class="text-gray-300 text-lg leading-relaxed mb-6">
            The safety of our community is our top priority. Our facility is monitored around the clock
            with a comprehensive security system to ensure that every visitor, worshipper, and child
            feels safe and protected at all times.
          </p>
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-white/10 backdrop-blur-sm rounded-xl p-5 border border-white/10">
              <div class="flex items-center gap-3 mb-2">
                <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
                <span class="text-2xl font-bold text-white">16+</span>
              </div>
              <div class="text-sm text-gray-400">Security Cameras</div>
            </div>
            <div class="bg-white/10 backdrop-blur-sm rounded-xl p-5 border border-white/10">
              <div class="flex items-center gap-3 mb-2">
                <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span class="text-2xl font-bold text-white">24/7</span>
              </div>
              <div class="text-sm text-gray-400">Monitoring</div>
            </div>
            <div class="bg-white/10 backdrop-blur-sm rounded-xl p-5 border border-white/10">
              <div class="flex items-center gap-3 mb-2">
                <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
                <span class="text-2xl font-bold text-white">Full</span>
              </div>
              <div class="text-sm text-gray-400">Coverage</div>
            </div>
            <div class="bg-white/10 backdrop-blur-sm rounded-xl p-5 border border-white/10">
              <div class="flex items-center gap-3 mb-2">
                <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
                <span class="text-2xl font-bold text-white">Interior</span>
              </div>
              <div class="text-sm text-gray-400">& Exterior</div>
            </div>
          </div>
        </div>
        <div>
          <div class="rounded-2xl overflow-hidden shadow-2xl border-2 border-white/10">
            <img
              src={url('/images/community-security-cameras.png')}
              alt="PWIC security camera monitoring system with 16+ cameras covering the entire facility"
              class="w-full h-auto object-cover"
              loading="lazy"
            />
          </div>
          <p class="text-center text-gray-400 text-sm mt-4">
            Our multi-camera monitoring system provides comprehensive coverage of the entire facility
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gradient-to-r from-primary-700 to-primary-600 rounded-3xl p-8 md:p-12 text-white text-center">
        <h3 class="text-2xl sm:text-3xl font-bold font-heading mb-4">Be Part of Our Community</h3>
        <p class="text-primary-100 mb-8 text-lg max-w-2xl mx-auto">
          Whether it's joining us for prayers, volunteering at an iftar, or enrolling your children
          in our programs — there's a place for you at PWIC.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href={url('/events')}
            class="px-8 py-3.5 bg-white text-primary-700 rounded-xl font-semibold hover:bg-primary-50 transition-colors shadow-lg"
          >
            Upcoming Events
          </a>
          <a
            href={url('/donate')}
            class="px-8 py-3.5 bg-amber-600 text-white rounded-xl font-semibold hover:bg-amber-700 transition-colors shadow-lg"
          >
            Support PWIC
          </a>
          <a
            href={url('/contact')}
            class="px-8 py-3.5 bg-primary-600 border border-primary-400 text-white rounded-xl font-semibold hover:bg-primary-500 transition-colors"
          >
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
