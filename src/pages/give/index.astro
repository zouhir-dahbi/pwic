---
/**
 * /give → Stripe payment link (used by NFC tags, QR codes, donation plaque)
 * 
 * Uses client-side JS to read ?amount= query param at runtime,
 * since static builds can't access query params server-side.
 */
import siteConfig from '../../data/site-config.json';

const stripeLink = siteConfig.donation.stripeLink || '';
const stripeAmountLinks: Record<string, string> = siteConfig.donation.stripeAmountLinks || {};
const fallbackUrl = '/donate';
---
<!doctype html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="robots" content="noindex">
  <title>Redirecting…</title>
  <script is:inline define:vars={{ stripeLink, stripeAmountLinks, fallbackUrl }}>
    (function() {
      if (!stripeLink) {
        window.location.href = fallbackUrl;
        return;
      }
      var params = new URLSearchParams(window.location.search);
      var amount = params.get('amount');
      if (amount && stripeAmountLinks[amount]) {
        window.location.replace(stripeAmountLinks[amount]);
        return;
      }
      window.location.replace(stripeLink);
    })();
  </script>
</head>
<body>
  <p>Redirecting to payment page…</p>
</body>
</html>
