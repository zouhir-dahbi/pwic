---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import siteConfig from '../data/site-config.json';
import { url } from '../utils/links';

const stripeLink = siteConfig.donation.stripeLink;
const stripeAmountLinks: Record<string, string> = siteConfig.donation.stripeAmountLinks || {};
const zelleEmail = siteConfig.donation.zelleEmail;
const paypalEmail = siteConfig.donation.paypalEmail;
const presetAmounts = siteConfig.donation.presetAmounts || [10, 20, 50];
const hasStripe = stripeLink && stripeLink.length > 0;
const hasPaypal = paypalEmail && paypalEmail.length > 0;
const giveUrl = url('/give');
const paypalDonateUrl = hasPaypal ? `https://www.paypal.com/donate?business=${encodeURIComponent(paypalEmail)}&currency_code=USD` : '';

function getAmountUrl(amount: number): string {
  const directLink = stripeAmountLinks[String(amount)];
  if (directLink) return directLink;
  return `${giveUrl}?amount=${amount}`;
}
---

<Layout title="Donate">
  <Hero 
    title="Support PWIC"
    subtitle="Your generous contributions help us serve the community"
    backgroundImage={url('/images/donation-heart-coins.jpeg')}
  />

  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Quran Verse -->
      <div class="text-center mb-12">
        <div class="inline-block bg-primary-50 rounded-2xl p-6 sm:p-8">
          <p class="text-lg sm:text-xl text-primary-800 italic font-heading leading-relaxed">
            "The example of those who spend their wealth in the way of Allah is like a seed 
            which grows seven spikes; in each spike is a hundred grains."
          </p>
          <p class="text-primary-600 mt-4 font-semibold">— The Holy Quran, 2:261</p>
        </div>
      </div>

      <!-- Donation Options Grid -->
      <div class={`grid gap-6 mb-12 ${hasPaypal ? 'md:grid-cols-3' : 'md:grid-cols-2'}`}>
        <!-- Online Donation (Stripe) -->
        <div class="bg-gradient-to-br from-primary-600 to-primary-700 rounded-2xl p-8 text-white shadow-xl relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full -translate-y-1/2 translate-x-1/2"></div>
          <div class="relative">
            <div class="w-16 h-16 bg-white/20 backdrop-blur-sm rounded-2xl flex items-center justify-center mb-6">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
            </div>
            <h3 class="text-2xl font-bold mb-2">Give Your Sadaqah</h3>
            <p class="text-white/80 mb-6">
              Choose an amount below. Secure payment via Stripe.
            </p>

            <!-- Preset Amount Buttons -->
            <div class="grid grid-cols-3 gap-3 mb-4">
              {presetAmounts.map((amount: number) => (
                <a
                  href={getAmountUrl(amount)}
                  class="flex items-center justify-center py-3.5 bg-white text-primary-700 rounded-xl font-bold text-lg hover:bg-primary-50 transition-colors shadow-md"
                >
                  ${amount}
                </a>
              ))}
            </div>

            <!-- Custom Amount Button -->
            <a
              href={giveUrl}
              class="flex items-center justify-center w-full py-3.5 bg-white/20 backdrop-blur-sm text-white border-2 border-white/30 rounded-xl font-semibold hover:bg-white/30 transition-colors"
            >
              Custom Amount
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>

            <p class="text-xs text-white/50 mt-4 text-center">Apple Pay · Google Pay · Credit / Debit</p>
          </div>
        </div>

        <!-- Zelle -->
        <div class="bg-white border-2 border-gray-200 rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow">
          <div class="w-16 h-16 bg-purple-100 rounded-2xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-purple-600" viewBox="0 0 24 24" fill="currentColor">
              <path d="M13.559 24h-2.841a.483.483 0 0 1-.483-.483v-5.769c-3.771-.17-6.235-1.26-6.235-3.596V6.178L.205 1.682A.483.483 0 0 1 .483 0h10.233c3.64 0 6.086 2.16 6.086 5.38 0 2.37-1.254 4.164-3.255 4.748v.06c2.625.47 4.248 2.468 4.248 5.074 0 3.9-2.974 6.354-7.657 6.697v1.558a.483.483 0 0 1-.483.483h-.096zM4.517 14.152c0 1.347 1.903 1.97 5.718 2.08V9.977c-3.815.109-5.718.732-5.718 2.08v2.095zm7.406 2.092c3.136-.12 4.872-1.272 4.872-3.015 0-1.744-1.736-2.896-4.872-3.016v6.031zm0-8.107c2.672-.12 4.159-1.117 4.159-2.757 0-1.64-1.487-2.636-4.159-2.756v5.513z"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-800 font-heading mb-2">Zelle</h3>
          <p class="text-gray-600 mb-6">
            Send directly from your bank app. Zero fees for you and PWIC.
          </p>
          {zelleEmail ? (
            <div class="bg-purple-50 rounded-xl p-4">
              <p class="text-xs text-purple-600 mb-1 uppercase tracking-wide font-medium">Send to:</p>
              <p class="text-lg font-bold text-purple-800 break-all">{zelleEmail}</p>
            </div>
          ) : (
            <div class="bg-gray-50 rounded-xl p-4 text-center">
              <p class="text-sm text-gray-500 font-semibold">Coming Soon</p>
            </div>
          )}
          <p class="text-xs text-gray-500 mt-4">Available in most US bank apps</p>
        </div>

        {hasPaypal && (
        <div class="bg-white border-2 border-gray-200 rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow">
          <div class="w-16 h-16 bg-blue-100 rounded-2xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-blue-600" viewBox="0 0 24 24" fill="currentColor">
              <path d="M7.076 21.337H2.47a.641.641 0 0 1-.633-.74L4.944 3.72a.771.771 0 0 1 .761-.654h5.36c2.404 0 4.156.777 4.748 2.555.187.563.238 1.086.163 1.664-.075.578-.272 1.22-.587 1.908a6.09 6.09 0 0 1-.758 1.224 5.076 5.076 0 0 1-1.113 1.084c-.432.318-.946.567-1.536.744-.579.172-1.236.26-1.961.26H8.468a.77.77 0 0 0-.76.653l-.001.007-.632 4.006-.001.007a.641.641 0 0 1-.633.546H7.076v.613zm13.302-14.07c-.104.623-.29 1.2-.562 1.725-.888 1.716-2.608 2.685-5.162 2.685h-1.23l-.696 4.405h-2.11l2.455-15.564h4.2c1.012 0 1.831.167 2.447.497.506.273.882.656 1.123 1.147.233.475.327 1.03.292 1.66-.013.219-.037.43-.072.632-.025.144-.055.289-.09.434-.054.224-.126.455-.214.695-.088.24-.194.483-.319.727-.058.115-.122.23-.192.343z"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-800 font-heading mb-2">PayPal</h3>
          <p class="text-gray-600 mb-6">
            Donate securely using your PayPal account or credit card.
          </p>
          <a
            href={paypalDonateUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center w-full py-3.5 bg-[#0070ba] text-white rounded-xl font-semibold hover:bg-[#005ea6] transition-colors shadow-md"
          >
            Donate with PayPal
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
          <p class="text-xs text-gray-500 mt-4">PayPal · Credit / Debit Card</p>
        </div>
        )}
      </div>

      <!-- Donation Types -->
      <div class="bg-gray-50 rounded-2xl p-6 sm:p-8 mb-12">
        <h3 class="text-2xl font-bold text-gray-800 font-heading mb-6 text-center">Types of Giving</h3>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <div class="bg-white rounded-xl p-5 text-center shadow-sm">
            <div class="w-12 h-12 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-3">
              <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h4 class="font-semibold text-gray-800 mb-1">Zakat</h4>
            <p class="text-xs text-gray-600">Obligatory annual charity</p>
          </div>
          <div class="bg-white rounded-xl p-5 text-center shadow-sm">
            <div class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-3">
              <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
            </div>
            <h4 class="font-semibold text-gray-800 mb-1">Sadaqah</h4>
            <p class="text-xs text-gray-600">Voluntary charity</p>
          </div>
          <div class="bg-white rounded-xl p-5 text-center shadow-sm">
            <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-3">
              <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
              </svg>
            </div>
            <h4 class="font-semibold text-gray-800 mb-1">Sadaqah Jariyah</h4>
            <p class="text-xs text-gray-600">Continuous charity</p>
          </div>
          <div class="bg-white rounded-xl p-5 text-center shadow-sm">
            <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-3">
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h4 class="font-semibold text-gray-800 mb-1">Monthly Giving</h4>
            <p class="text-xs text-gray-600">Recurring support</p>
          </div>
        </div>
      </div>

      <!-- Where Your Donation Goes -->
      <div class="mb-12">
        <h3 class="text-2xl font-bold text-gray-800 font-heading mb-8 text-center">Where Your Donation Goes</h3>
        <div class="grid sm:grid-cols-2 gap-4">
          <div class="flex items-start gap-4 bg-white rounded-xl p-4 border border-gray-100">
            <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-gray-800">Masjid Operations</h4>
              <p class="text-sm text-gray-600">Utilities, maintenance, and facilities</p>
            </div>
          </div>
          <div class="flex items-start gap-4 bg-white rounded-xl p-4 border border-gray-100">
            <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-gray-800">Educational Programs</h4>
              <p class="text-sm text-gray-600">Weekend School & youth programs</p>
            </div>
          </div>
          <div class="flex items-start gap-4 bg-white rounded-xl p-4 border border-gray-100">
            <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-gray-800">Community Services</h4>
              <p class="text-sm text-gray-600">Family support & community events</p>
            </div>
          </div>
          <div class="flex items-start gap-4 bg-white rounded-xl p-4 border border-gray-100">
            <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-gray-800">Special Programs</h4>
              <p class="text-sm text-gray-600">Ramadan, Eid & Islamic events</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Other Ways -->
      <div class="text-center bg-white rounded-2xl p-6 border border-gray-100">
        <h4 class="font-semibold text-gray-800 mb-2">Other Ways to Give</h4>
        <p class="text-gray-600 text-sm">
          Cash or check donations can be dropped off at the masjid during prayer times.
        </p>
      </div>
    </div>
  </section>

  <!-- Tax Deductible Notice -->
  <section class="py-8 bg-primary-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-primary-700">
        <strong>Tax Deductible:</strong> Prince William Islamic Center is a registered 501(c)(3) nonprofit organization. 
        Your donations may be tax deductible.
      </p>
    </div>
  </section>
</Layout>
