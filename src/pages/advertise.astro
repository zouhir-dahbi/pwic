---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import { url } from '../utils/links';
import directoryData from '../data/business-directory.json';

const businesses = directoryData.businesses.filter(b => b.active);
const categories = directoryData.categories;
const annualFee = directoryData.pricing.annualFee;
const monthlyFee = Math.round(annualFee / 12);
---

<Layout title="Community Business Directory" description="Discover trusted community businesses and list yours for $240/year at Prince William Islamic Center.">
  <Hero
    title="Community Business Directory"
    subtitle="Discover trusted businesses recommended by your PWIC community"
  />

  <!-- Business Listings -->
  <section class="py-14 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-10">
        <div>
          <span class="inline-block px-4 py-1.5 bg-primary-100 text-primary-700 rounded-full text-sm font-semibold mb-3">Support Local Businesses</span>
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-800 font-heading">Listed Businesses</h2>
          <p class="text-gray-500 mt-1">{businesses.length} {businesses.length === 1 ? 'business' : 'businesses'} in our directory</p>
        </div>
        <div class="relative">
          <select id="category-filter" class="appearance-none bg-white border border-gray-200 rounded-xl px-5 py-3 pr-10 text-sm font-medium text-gray-700 shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 cursor-pointer">
            <option value="all">All Categories</option>
            {categories.map(cat => (
              <option value={cat}>{cat}</option>
            ))}
          </select>
          <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
      </div>

      <!-- Business Cards Grid -->
      <div id="business-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {businesses.map(biz => (
          <div class="business-card group bg-white rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100 hover:-translate-y-1" data-category={biz.category}>
            <div class="relative h-48 bg-gradient-to-br from-gray-100 to-gray-50 overflow-hidden">
              {biz.image ? (
                <img
                  src={url(biz.image)}
                  alt={`${biz.name} business card`}
                  class="w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center">
                  <div class="text-center">
                    <svg class="w-16 h-16 text-gray-300 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                    </svg>
                    <span class="text-gray-400 text-sm">{biz.name}</span>
                  </div>
                </div>
              )}
              {biz.featured && (
                <span class="absolute top-3 right-3 px-3 py-1 bg-amber-500 text-white text-xs font-bold rounded-full shadow-md">
                  Featured
                </span>
              )}
              <span class="absolute top-3 left-3 px-3 py-1 bg-white/90 backdrop-blur-sm text-gray-700 text-xs font-semibold rounded-full shadow-sm">
                {biz.category}
              </span>
            </div>

            <div class="p-5">
              <h3 class="text-lg font-bold text-gray-800 mb-1 group-hover:text-primary-600 transition-colors">{biz.name}</h3>
              {biz.contact.name && (
                <p class="text-sm text-primary-600 font-medium mb-2">
                  {biz.contact.name}{biz.contact.title ? ` — ${biz.contact.title}` : ''}
                </p>
              )}
              <p class="text-gray-600 text-sm mb-4 line-clamp-2">{biz.description}</p>

              {biz.services && biz.services.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mb-4">
                  {biz.services.map(svc => (
                    <span class="px-2.5 py-1 bg-primary-50 text-primary-700 text-xs font-medium rounded-lg">{svc}</span>
                  ))}
                </div>
              )}

              <div class="space-y-2 text-sm text-gray-600 border-t border-gray-100 pt-4">
                {biz.contact.phone && (
                  <a href={`tel:${biz.contact.phone.replace(/[^0-9+]/g, '')}`} class="flex items-center gap-2 hover:text-primary-600 transition-colors">
                    <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                    <span>{biz.contact.phone}</span>
                  </a>
                )}
                {biz.contact.email && (
                  <a href={`mailto:${biz.contact.email}`} class="flex items-center gap-2 hover:text-primary-600 transition-colors">
                    <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                    <span class="truncate">{biz.contact.email}</span>
                  </a>
                )}
                {biz.address && (
                  <div class="flex items-start gap-2">
                    <svg class="w-4 h-4 text-gray-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <span>{biz.address}</span>
                  </div>
                )}
                {biz.website && (
                  <a href={biz.website} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 hover:text-primary-600 transition-colors">
                    <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                    </svg>
                    <span class="truncate">{biz.website.replace(/^https?:\/\/(www\.)?/, '')}</span>
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Empty State -->
      <div id="no-results" class="hidden text-center py-16">
        <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <h3 class="text-xl font-bold text-gray-400 mb-2">No businesses found</h3>
        <p class="text-gray-400">No businesses match the selected category. Try selecting a different one.</p>
      </div>
    </div>
  </section>

  <!-- List Your Business -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gradient-to-br from-primary-800 via-primary-700 to-primary-900 rounded-3xl overflow-hidden shadow-2xl">
        <div class="grid lg:grid-cols-2 gap-0">
          <div class="p-8 md:p-12 flex flex-col justify-center">
            <span class="inline-block w-fit px-4 py-1.5 bg-white/10 text-primary-200 rounded-full text-sm font-semibold mb-5 border border-white/10">
              For Business Owners
            </span>
            <h2 class="text-3xl sm:text-4xl font-bold text-white font-heading mb-4">List Your Business</h2>
            <p class="text-primary-100 text-lg mb-6 leading-relaxed">
              Get your business in front of hundreds of Muslim families in Manassas, Centreville,
              Gainesville, and surrounding areas. Your listing supports our masjid's programs too.
            </p>

            <div class="space-y-4 mb-8">
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <span class="text-primary-100">Prominent listing with your business card</span>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <span class="text-primary-100">Clickable contact info — phone, email, website, and address</span>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <span class="text-primary-100">Exposure to the entire PWIC community</span>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <span class="text-primary-100">Your listing fee directly supports the masjid</span>
              </div>
            </div>

            <a
              href={url('/contact')}
              class="inline-flex items-center justify-center gap-2 w-fit px-8 py-4 bg-white text-primary-700 rounded-xl font-bold text-lg hover:bg-primary-50 transition-colors shadow-lg"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              Contact Us to Get Listed
            </a>
          </div>

          <div class="p-8 md:p-12 flex items-center justify-center bg-white/5 backdrop-blur-sm">
            <div class="bg-white rounded-2xl p-8 shadow-xl text-center max-w-sm w-full">
              <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
              </div>
              <h3 class="text-xl font-bold text-gray-800 mb-2">Annual Listing</h3>
              <div class="mb-4">
                <span class="text-5xl font-bold text-primary-600">${annualFee}</span>
                <span class="text-gray-500 text-lg">/year</span>
              </div>
              <p class="text-gray-500 text-sm mb-6">Only ${monthlyFee}/month to grow your business</p>
              <div class="space-y-3 text-left mb-6">
                <div class="flex items-center gap-2 text-sm text-gray-600">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Business card displayed on website
                </div>
                <div class="flex items-center gap-2 text-sm text-gray-600">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Full contact information
                </div>
                <div class="flex items-center gap-2 text-sm text-gray-600">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Category &amp; service tags
                </div>
                <div class="flex items-center gap-2 text-sm text-gray-600">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Link to your website
                </div>
                <div class="flex items-center gap-2 text-sm text-gray-600">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Update your listing anytime
                </div>
              </div>
              <a
                href={url('/contact')}
                class="block w-full px-6 py-3.5 bg-primary-600 text-white rounded-xl font-semibold hover:bg-primary-700 transition-colors shadow-md"
              >
                Get Started
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-800 font-heading mb-3">How It Works</h2>
        <p class="text-gray-600 text-lg">Three simple steps to get listed</p>
      </div>

      <div class="grid sm:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-14 h-14 bg-primary-600 text-white rounded-2xl flex items-center justify-center mx-auto mb-4 text-xl font-bold shadow-md">1</div>
          <h3 class="font-bold text-gray-800 mb-2 text-lg">Contact Us</h3>
          <p class="text-gray-600 text-sm">Reach out via our contact page or email with your business details</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 bg-primary-600 text-white rounded-2xl flex items-center justify-center mx-auto mb-4 text-xl font-bold shadow-md">2</div>
          <h3 class="font-bold text-gray-800 mb-2 text-lg">Send Your Info</h3>
          <p class="text-gray-600 text-sm">Provide your business card, description, contact info, and services</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 bg-primary-600 text-white rounded-2xl flex items-center justify-center mx-auto mb-4 text-xl font-bold shadow-md">3</div>
          <h3 class="font-bold text-gray-800 mb-2 text-lg">Go Live</h3>
          <p class="text-gray-600 text-sm">Once your ${annualFee} annual fee is paid, your listing goes live</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-14 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-800 font-heading mb-3">Frequently Asked Questions</h2>
        <p class="text-gray-600">Common questions about listing your business</p>
      </div>

      <div class="space-y-4">
        <div class="faq-item bg-white rounded-xl border border-gray-200 overflow-hidden">
          <button class="faq-trigger w-full flex items-center justify-between px-6 py-5 text-left">
            <span class="font-semibold text-gray-800">How do I list my business?</span>
            <svg class="faq-arrow w-5 h-5 text-gray-400 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-content hidden px-6 pb-5">
            <p class="text-gray-600">
              Contact us via our <a href={url('/contact')} class="text-primary-600 font-medium hover:underline">Contact page</a>
              or email us directly. Provide your business card, a short description of your services,
              and your contact information. Once your annual fee of ${annualFee} is paid, your listing goes live.
            </p>
          </div>
        </div>

        <div class="faq-item bg-white rounded-xl border border-gray-200 overflow-hidden">
          <button class="faq-trigger w-full flex items-center justify-between px-6 py-5 text-left">
            <span class="font-semibold text-gray-800">How much does it cost?</span>
            <svg class="faq-arrow w-5 h-5 text-gray-400 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-content hidden px-6 pb-5">
            <p class="text-gray-600">
              An annual listing costs ${annualFee}/year (just ${monthlyFee}/month). This covers your business card display,
              full contact information, and a link to your website. The fee supports our masjid's community programs.
            </p>
          </div>
        </div>

        <div class="faq-item bg-white rounded-xl border border-gray-200 overflow-hidden">
          <button class="faq-trigger w-full flex items-center justify-between px-6 py-5 text-left">
            <span class="font-semibold text-gray-800">Can I update my listing information?</span>
            <svg class="faq-arrow w-5 h-5 text-gray-400 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-content hidden px-6 pb-5">
            <p class="text-gray-600">
              Yes! You can request updates to your listing at any time — new contact info, updated business card,
              or changes to your description and services. Just reach out via our contact page.
            </p>
          </div>
        </div>

        <div class="faq-item bg-white rounded-xl border border-gray-200 overflow-hidden">
          <button class="faq-trigger w-full flex items-center justify-between px-6 py-5 text-left">
            <span class="font-semibold text-gray-800">Are there any restrictions on who can list?</span>
            <svg class="faq-arrow w-5 h-5 text-gray-400 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-content hidden px-6 pb-5">
            <p class="text-gray-600">
              All businesses are welcome to apply. Listings are subject to review and must align with
              Islamic values. We reserve the right to decline or remove listings that do not meet our community standards.
            </p>
          </div>
        </div>
      </div>

      <p class="text-center text-sm text-gray-500 mt-8">
        All listings are subject to approval. We reserve the right to decline listings that do not align with Islamic values.
      </p>
    </div>
  </section>
</Layout>

<script>
  const filter = document.getElementById('category-filter') as HTMLSelectElement;
  const noResults = document.getElementById('no-results');
  const cards = document.querySelectorAll('.business-card');

  filter?.addEventListener('change', () => {
    const selected = filter.value;
    let visible = 0;

    cards.forEach(card => {
      const category = card.getAttribute('data-category');
      const show = selected === 'all' || category === selected;
      (card as HTMLElement).style.display = show ? '' : 'none';
      if (show) visible++;
    });

    if (noResults) {
      noResults.classList.toggle('hidden', visible > 0);
    }
  });

  document.querySelectorAll('.faq-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('.faq-item');
      const content = item?.querySelector('.faq-content');
      const arrow = item?.querySelector('.faq-arrow');

      document.querySelectorAll('.faq-item').forEach(other => {
        if (other !== item) {
          other.querySelector('.faq-content')?.classList.add('hidden');
          other.querySelector('.faq-arrow')?.classList.remove('rotate-180');
        }
      });

      content?.classList.toggle('hidden');
      arrow?.classList.toggle('rotate-180');
    });
  });
</script>
