---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import { url } from '../utils/links';
import directoryData from '../data/business-directory.json';

const annualFee = directoryData.pricing.annualFee;
const monthlyFee = Math.round(annualFee / 12);
const businessCount = directoryData.businesses.filter(b => b.active).length;
---

<Layout title="Advertise With Us" description="List your business in the PWIC Community Business Directory for $240/year and reach hundreds of Muslim families in Northern Virginia.">
  <Hero
    title="Grow Your Business With PWIC"
    subtitle="List your business in our Community Directory and connect with hundreds of Muslim families"
  />

  <!-- Pricing + Value -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Left: Value Proposition -->
        <div>
          <span class="inline-block px-4 py-1.5 bg-purple-100 text-purple-700 rounded-full text-sm font-semibold mb-5">Community Business Directory</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-800 font-heading mb-5">
            Put Your Business in Front of the Entire PWIC Community
          </h2>
          <p class="text-gray-600 text-lg leading-relaxed mb-8">
            Our Community Business Directory is the go-to resource for Muslim families in Manassas,
            Centreville, Gainesville, and surrounding areas looking for trusted local businesses.
            Your listing supports our masjid's programs while growing your customer base.
          </p>

          <div class="space-y-4 mb-8">
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <span class="text-gray-700">Your business card prominently displayed on our website</span>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <span class="text-gray-700">Clickable phone, email, website, and address</span>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <span class="text-gray-700">Category tags and service descriptions for easy discovery</span>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <span class="text-gray-700">Trusted association with Prince William Islamic Center</span>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <span class="text-gray-700">Your listing fee directly supports masjid programs</span>
            </div>
          </div>

          <a
            href={url('/business-directory')}
            class="inline-flex items-center gap-2 text-primary-600 font-semibold hover:text-primary-700 transition-colors"
          >
            View the Business Directory
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>

        <!-- Right: Pricing Card -->
        <div class="flex justify-center">
          <div class="bg-white rounded-2xl p-8 shadow-xl border-2 border-primary-100 text-center max-w-sm w-full">
            <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-2">Annual Listing</h3>
            <div class="mb-2">
              <span class="text-5xl font-bold text-primary-600">${annualFee}</span>
              <span class="text-gray-500 text-lg">/year</span>
            </div>
            <p class="text-gray-500 text-sm mb-6">Only ${monthlyFee}/month to grow your business</p>

            <div class="space-y-3 text-left mb-8">
              <div class="flex items-center gap-2 text-sm text-gray-600">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Business card displayed on website
              </div>
              <div class="flex items-center gap-2 text-sm text-gray-600">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Full contact information
              </div>
              <div class="flex items-center gap-2 text-sm text-gray-600">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Category &amp; service tags
              </div>
              <div class="flex items-center gap-2 text-sm text-gray-600">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Link to your website
              </div>
              <div class="flex items-center gap-2 text-sm text-gray-600">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Update your listing anytime
              </div>
            </div>

            <a
              href={url('/contact')}
              class="block w-full px-6 py-3.5 bg-primary-600 text-white rounded-xl font-semibold hover:bg-primary-700 transition-colors shadow-md text-center"
            >
              Get Started
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-800 font-heading mb-3">How It Works</h2>
        <p class="text-gray-600 text-lg">Three simple steps to get listed</p>
      </div>

      <div class="grid sm:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-14 h-14 bg-primary-600 text-white rounded-2xl flex items-center justify-center mx-auto mb-4 text-xl font-bold shadow-md">1</div>
          <h3 class="font-bold text-gray-800 mb-2 text-lg">Contact Us</h3>
          <p class="text-gray-600 text-sm">Reach out via our contact page or email with your business details</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 bg-primary-600 text-white rounded-2xl flex items-center justify-center mx-auto mb-4 text-xl font-bold shadow-md">2</div>
          <h3 class="font-bold text-gray-800 mb-2 text-lg">Send Your Info</h3>
          <p class="text-gray-600 text-sm">Provide your business card, description, contact info, and services</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 bg-primary-600 text-white rounded-2xl flex items-center justify-center mx-auto mb-4 text-xl font-bold shadow-md">3</div>
          <h3 class="font-bold text-gray-800 mb-2 text-lg">Go Live</h3>
          <p class="text-gray-600 text-sm">Once your ${annualFee} annual fee is paid, your listing goes live on the directory</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gradient-to-r from-primary-700 to-primary-600 rounded-3xl p-8 md:p-12 text-white text-center">
        <h3 class="text-2xl sm:text-3xl font-bold font-heading mb-4">Ready to Get Listed?</h3>
        <p class="text-primary-100 mb-8 text-lg max-w-2xl mx-auto">
          Join our growing directory of community businesses. Get exposure to the entire PWIC community
          while supporting our masjid.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href={url('/contact')}
            class="inline-flex items-center gap-2 px-8 py-4 bg-white text-primary-700 rounded-xl font-bold hover:bg-primary-50 transition-colors shadow-lg"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Contact Us to Get Listed
          </a>
          <a
            href={url('/business-directory')}
            class="px-8 py-4 bg-primary-600 border border-primary-400 text-white rounded-xl font-semibold hover:bg-primary-500 transition-colors"
          >
            View the Directory
          </a>
        </div>
      </div>

      <p class="text-center text-sm text-gray-500 mt-8">
        All listings are subject to approval. We reserve the right to decline listings that do not align with Islamic values.
      </p>
    </div>
  </section>
</Layout>
